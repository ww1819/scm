<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.system.mapper.HospitalUserMapper">

    <resultMap type="HospitalUser" id="HospitalUserResult">
        <id     property="hospitalUserId" column="hospital_user_id" />
        <result property="hospitalId"     column="hospital_id"      />
        <result property="userId"       column="user_id"         />
        <result property="isMain"       column="is_main"         />
        <result property="status"       column="status"          />
        <result property="hospitalName" column="hospital_name"    />
    </resultMap>

    <select id="selectHospitalUserByUserId" parameterType="Long" resultMap="HospitalUserResult">
        select hu.hospital_user_id, hu.hospital_id, hu.user_id, hu.is_main, hu.status,
               h.hospital_name
        from scm_hospital_user hu
        left join scm_hospital h on hu.hospital_id = h.hospital_id
        where hu.user_id = #{userId}
          and (hu.del_flag = '0' or hu.del_flag is null)
        order by hu.is_main desc, hu.create_time desc
        limit 1
    </select>

    <insert id="insertHospitalUser" parameterType="HospitalUser" useGeneratedKeys="true" keyProperty="hospitalUserId">
        insert into scm_hospital_user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="hospitalId != null">hospital_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="isMain != null">is_main,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="hospitalId != null">#{hospitalId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="isMain != null">#{isMain},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <delete id="deleteHospitalUserByUserId">
        delete from scm_hospital_user where user_id = #{userId}
    </delete>
</mapper>
