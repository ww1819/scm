<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scm.system.mapper.ScmReconciliationMapper">

    <resultMap type="ScmReconciliation" id="ScmReconciliationResult">
        <id     property="reconciliationId" column="reconciliation_id" />
        <result property="hospitalId"       column="hospital_id" />
        <result property="hospitalName"     column="hospital_name" />
        <result property="reconcileDate"    column="reconcile_date" />
        <result property="hisAmount"        column="his_amount" />
        <result property="spdAmount"        column="spd_amount" />
        <result property="itemCount"        column="item_count" />
        <result property="abnormalCount"    column="abnormal_count" />
        <result property="status"           column="status" />
        <result property="createBy"         column="create_by" />
        <result property="createTime"       column="create_time" />
        <result property="updateBy"         column="update_by" />
        <result property="updateTime"       column="update_time" />
        <result property="remark"           column="remark" />
    </resultMap>

    <select id="selectReconciliationList" parameterType="ScmReconciliation" resultMap="ScmReconciliationResult">
        select reconciliation_id, hospital_id, hospital_name, reconcile_date,
               his_amount, spd_amount, item_count, abnormal_count, status,
               create_by, create_time, update_by, update_time, remark
        from scm_reconciliation
        <where>
            <if test="hospitalId != null">
                AND hospital_id = #{hospitalId}
            </if>
            <if test="monthBegin != null and monthBegin != ''">
                AND reconcile_date &gt;= #{monthBegin}
            </if>
            <if test="monthEnd != null and monthEnd != ''">
                AND reconcile_date &lt;= #{monthEnd}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by reconcile_date asc
    </select>

</mapper>
